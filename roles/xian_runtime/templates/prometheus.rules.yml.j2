groups:
{% if xian_monitoring_alert_preset == "embedded_backend" %}
  - name: xian_embedded_backend
    rules:
      - alert: XianAbciTargetDown
        expr: up{job="xian_abci"} == 0
        for: 2m
        labels:
          severity: critical
          preset: embedded_backend
        annotations:
          summary: Xian ABCI metrics target is down
          description: The Xian ABCI metrics endpoint has been unreachable for more than two minutes.
      - alert: XianNodeInfoMissing
        expr: absent(xian_node_info)
        for: 2m
        labels:
          severity: critical
          preset: embedded_backend
        annotations:
          summary: Xian node info metric is missing
          description: The Xian app metrics exporter is reachable, but xian_node_info has not been observed for more than two minutes.
      - alert: XianCometBftTargetDown
        expr: up{job="xian_cometbft"} == 0
        for: 2m
        labels:
          severity: critical
          preset: embedded_backend
        annotations:
          summary: CometBFT metrics target is down
          description: The CometBFT metrics endpoint has been unreachable for more than two minutes.
      - alert: XianBdsLagHigh
        expr: xian_bds_metric{field="height_lag"} > 10
        for: 10m
        labels:
          severity: warning
          preset: embedded_backend
        annotations:
          summary: BDS indexing lag is elevated
          description: BDS height lag has stayed above 10 blocks for ten minutes.
      - alert: XianBdsAlertsPresent
        expr: sum(xian_bds_alert) > 0
        for: 5m
        labels:
          severity: warning
          preset: embedded_backend
        annotations:
          summary: The node is reporting active BDS alerts
          description: One or more BDS alerts have remained active for at least five minutes.
      - alert: XianFinalizeSlow
        expr: xian_perf_global_metric{metric="finalize_block",stat="avg_ms"} > 1000
        for: 10m
        labels:
          severity: warning
          preset: embedded_backend
        annotations:
          summary: FinalizeBlock average latency is elevated
          description: Average FinalizeBlock latency has stayed above 1000 ms for ten minutes.
      - alert: XianVmShadowMismatchDetected
        expr: sum(xian_vm_shadow_metric{field="mismatches_total"}) > 0
        for: 1m
        labels:
          severity: critical
          preset: embedded_backend
        annotations:
          summary: Xian VM native/shadow mismatch detected
          description: One or more native-vs-shadow mismatches have been recorded and remained present for at least one minute.
{% elif xian_monitoring_alert_preset == "shared_network" %}
  - name: xian_shared_network
    rules:
      - alert: XianAbciTargetDown
        expr: up{job="xian_abci"} == 0
        for: 2m
        labels:
          severity: critical
          preset: shared_network
        annotations:
          summary: Xian ABCI metrics target is down
          description: The Xian ABCI metrics endpoint has been unreachable for more than two minutes.
      - alert: XianNodeInfoMissing
        expr: absent(xian_node_info)
        for: 2m
        labels:
          severity: critical
          preset: shared_network
        annotations:
          summary: Xian node info metric is missing
          description: The Xian app metrics exporter is reachable, but xian_node_info has not been observed for more than two minutes.
      - alert: XianCometBftTargetDown
        expr: up{job="xian_cometbft"} == 0
        for: 2m
        labels:
          severity: critical
          preset: shared_network
        annotations:
          summary: CometBFT metrics target is down
          description: The CometBFT metrics endpoint has been unreachable for more than two minutes.
      - alert: XianSharedNetworkBlockProgressStalled
        expr: increase(xian_current_block_height[15m]) < 1
        for: 15m
        labels:
          severity: critical
          preset: shared_network
        annotations:
          summary: Block progress appears stalled
          description: Block height has not advanced over the last fifteen minutes on a shared-network posture.
      - alert: XianBdsLagHigh
        expr: xian_bds_metric{field="height_lag"} > 5
        for: 10m
        labels:
          severity: warning
          preset: shared_network
        annotations:
          summary: BDS indexing lag is elevated
          description: BDS height lag has stayed above five blocks for ten minutes.
      - alert: XianBdsAlertsPresent
        expr: sum(xian_bds_alert) > 0
        for: 5m
        labels:
          severity: warning
          preset: shared_network
        annotations:
          summary: The node is reporting active BDS alerts
          description: One or more BDS alerts have remained active for at least five minutes.
      - alert: XianVmShadowMismatchDetected
        expr: sum(xian_vm_shadow_metric{field="mismatches_total"}) > 0
        for: 1m
        labels:
          severity: critical
          preset: shared_network
        annotations:
          summary: Xian VM native/shadow mismatch detected
          description: One or more native-vs-shadow mismatches have been recorded and remained present for at least one minute.
{% else %}
  - name: xian_monitoring_none
    rules: []
{% endif %}
