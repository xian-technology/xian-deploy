from pathlib import Path

from xian.cli.configure_node import main


args = []


def add(*values):
    args.extend(str(value) for value in values)


def add_secret_file(flag, path, include_empty=False):
    secret = Path(path).read_text(encoding="utf-8").strip()
    if secret or include_empty:
        add(flag, secret)


